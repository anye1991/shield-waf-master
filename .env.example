# ============================================
# 盾甲 WAF v3.1.0 环境变量配置
# ============================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 修改下面的值为你的实际配置
#   3. .env 文件已被 Nginx 规则禁止外部访问，确保安全
#   4. 如果服务器环境变量（如 fastcgi_param）已设置同名变量，.env 中的值不会覆盖
#
# 优先级：服务器环境变量 > .env 文件 > config.php 默认值

# ======================== 密钥配置（必须修改！） ========================

# 暗门魔法密钥（第一因子），建议 32 字符以上的随机字符串
WAF_MAGIC_KEY=change-me-magic-key-32-chars-min

# 二次验证密码（第二因子）
WAF_2FA_PASS=change-me-2fa-password

# ======================== 告警配置 ========================

# Webhook 告警地址（支持企业微信/钉钉/Slack 等）
# 留空则不启用告警
WAF_WEBHOOK_URL=

# ======================== CDN 配置 ========================

# 是否信任 Cloudflare 的 CF-Connecting-IP 头
# 如果使用 Cloudflare CDN，设为 true
WAF_TRUST_CF_IP=false

# ======================== 机器人检测 ========================

# 是否通过 DNS 反向解析验证搜索引擎蜘蛛真实性
# true = 启用 DNS 反查（推荐高安全需求站点）
# false = 仅通过 UA + 头特征验证（默认，零延迟）
WAF_BOT_VERIFY_DNS=false

# ======================== 暗门配置 ========================

# 暗门有效期（秒）
WAF_MAGIC_EXPIRE=3600

# 暗门最大重试次数
WAF_MAGIC_MAX_RETRY=3

# ======================== CC 攻击防护 ========================

# CC 攻击请求限制数（每个窗口内的最大请求数）
WAF_CC_LIMIT=60

# CC 攻击时间窗口（秒）
WAF_CC_WINDOW=60

# ======================== 核心性能配置 ========================

# 请求体最大读取大小（字节），1MB
WAF_MAX_BODY_SIZE=1048576

# 最大编码递归深度
WAF_MAX_ENCODING_DEPTH=8

# 单个参数最大长度
WAF_MAX_PAYLOAD_SIZE=100000

# 单日志文件最大大小（字节），10MB
WAF_LOG_MAX_FILESIZE=10485760

# ======================== 安全功能开关 ========================

# 语义引擎开关
WAF_SEMANTIC_ENABLED=true

# 评分系统开关
WAF_SCORER_ENABLED=true

# 自动学习开关
WAF_AUTOLEARN_ENABLED=true

# 登录后重新生成 session id
WAF_SESSION_REGENERATE=true

# 自定义 CSP 字符串（留空用默认）
SHIELD_WAF_CSP=

# 自定义权限策略（留空用默认）
SHIELD_WAF_PERMISSIONS_POLICY=

# ======================== CORS 配置 ========================

# 允许的 CORS 源，逗号分隔，留空=同源
WAF_ALLOWED_ORIGINS=

# ======================== 沙箱配置 ========================

# 自动扫描间隔（秒），默认 300 = 5 分钟
WAF_SANDBOX_SCAN_INTERVAL=300

# ======================== 语义引擎配置 ========================

# 语义分析是否启用
WAF_SEMANTIC_ENGINE=true

# 语义记忆池是否启用
WAF_SEMANTIC_MEMORY=true

# 攻击链分析是否启用
WAF_ATTACK_CHAIN=true

# ======================== 主动防御配置 ========================

# 主动防御是否启用
WAF_ACTIVE_DEFENSE=true

# 蜜罐是否启用
WAF_HONEYTRAP=true

# 攻击路径预判是否启用
WAF_PATH_PREDICTION=true

# 误报控制是否启用
WAF_FALSE_POSITIVE_GUARD=true

# ======================== 评分系统配置 ========================

# 拦截阈值（总分>=此值拦截）
WAF_SCORE_BLOCK=60

# 监控阈值（总分>=此值记录日志但不拦截）
WAF_SCORE_MONITOR=40
