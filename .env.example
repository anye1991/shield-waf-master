# ============================================
# 盾甲 WAF v4.2.0 环境变量配置
# ============================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 修改下面的值为你的实际配置
#   3. .env 文件已被 Nginx 规则禁止外部访问，确保安全
#   4. 如果服务器环境变量（如 fastcgi_param）已设置同名变量，.env 中的值不会覆盖
#
# 优先级：服务器环境变量 > .env 文件 > config.php 默认值

# ======================== 密钥配置（必须修改！） ========================

# 暗门魔法密钥（第一因子），建议 32 字符以上的随机字符串
WAF_MAGIC_KEY=change-me-magic-key-32-chars-min

# 二次验证密码（第二因子）
# ============================================================
# 双重哈希密码策略（v3.1.0+）：
#   - 首次安装：直接写明文（如下），系统首次加载会自动迁移到 logs/password_hash.json
#     WAF_2FA_PASS=your-plaintext-password
#   - 迁移后：可从 .env 删除 WAF_2FA_PASS（推荐），系统自动从 hash 文件读
#   - 修改密码：访问控制台「密码管理」页生成 hash，或调用 /waf-password-api?action=migrate
#
# 也可以直接在 .env 写双重哈希字符串（不推荐明文修改）：
#   WAF_2FA_PASS=dual$v1$<base64-json>
#
# 双重哈希格式：Argon2id（主层）+ bcrypt cost=10（副层），两层都必须通过验证
# 算法优先级（自动检测环境）：
#   1. argon2id-sodium  (ext-sodium，抗 GPU/ASIC 最强)
#   2. argon2id         (PASSWORD_ARGON2ID)
#   3. argon2i          (PASSWORD_ARGON2I)
#   4. bcrypt cost=12   (兜底)
# ============================================================
WAF_2FA_PASS=change-me-2fa-password

# ======================== 网站密码双重加密服务（可选） ========================
# 任意 PHP 网站都能启用，使数据库用户密码存储为双重加密（Argon2id + bcrypt）
# 即使数据库泄露，破解成本也大幅提升（双重哈希 + 随机盐）
#
# 启用方式：在网站代码中引入 ShieldPasswordService，详见文档
#
# 是否启用（默认 false，不影响 WAF 自身功能）
WAF_PASSWORD_SERVICE_ENABLED=false
#
# 数据库类型：auto/mysqli/pdo_mysql/pdo_pgsql/pdo_sqlite/pdo_sqlsrv
# 设为 auto 时自动检测当前环境可用的数据库扩展
WAF_PASSWORD_DB_DRIVER=auto
#
# 网站用户表配置（根据你的实际表结构修改）
# WAF_PASSWORD_DB_TABLE=users
# WAF_PASSWORD_DB_ID_COL=id
# WAF_PASSWORD_DB_NAME_COL=username
# WAF_PASSWORD_DB_PASS_COL=password
#
# 数据库连接配置（与 WAF 无关的网站库）
# WAF_PASSWORD_DB_HOST=localhost
# WAF_PASSWORD_DB_PORT=3306
# WAF_PASSWORD_DB_NAME=website_db
# WAF_PASSWORD_DB_USER=dbuser
# WAF_PASSWORD_DB_PASS=dbpass
#
# WordPress 集成（设为 true 自动接管 wp_hash_password/wp_check_password）
# WAF_PASSWORD_WP_INTEGRATION=true

# ======================== 告警配置 ========================

# Webhook 告警地址（支持企业微信/钉钉/Slack 等）
# 留空则不启用告警
WAF_WEBHOOK_URL=

# ======================== CDN 配置 ========================

# 是否信任 Cloudflare 的 CF-Connecting-IP 头
# 如果使用 Cloudflare CDN，设为 true
WAF_TRUST_CF_IP=false

# ======================== 机器人检测 ========================

# 是否通过 DNS 反向解析验证搜索引擎蜘蛛真实性
# true = 启用 DNS 反查（推荐高安全需求站点）
# false = 仅通过 UA + 头特征验证（默认，零延迟）
WAF_BOT_VERIFY_DNS=false

# ======================== 暗门配置 ========================

# 暗门有效期（秒）
WAF_MAGIC_EXPIRE=3600

# 暗门最大重试次数
WAF_MAGIC_MAX_RETRY=3

# ======================== CC 攻击防护 ========================

# CC 攻击请求限制数（每个窗口内的最大请求数）
WAF_CC_LIMIT=120

# CC 攻击时间窗口（秒）
WAF_CC_WINDOW=60

# AJAX 请求速率上限（wp-json/admin-ajax/heartbeat 等）
WAF_CC_LIMIT_AJAX=240

# 单 IP 日志文件最大行数（防止日志无限增长）
WAF_CC_FILE_MAX_PER_IP=1000

# 异步清理触发间隔（每 N 次请求清理一次过期记录）
WAF_CC_CLEANUP_INTERVAL=100

# 是否跳过速率限制（调试/内网白名单场景使用，生产环境务必 false）
WAF_SKIP_RATELIMIT=false

# ======================== 测试模式 ========================
# 测试模式：只拦截不封IP，方便部署期间调试
# true = 开启（仅测试用，生产环境务必 false）
# false = 关闭（正常模式）
WAF_TEST_MODE=false

# 管理员 IP 白名单（逗号分隔，支持 CIDR 网段）
# 白名单 IP 跳过速率限制、封禁检查、累进封禁
WAF_ADMIN_IPS=

# ======================== 错误掩码 ========================
# 是否启用错误信息掩码（生产环境建议开启）
# 开启后 PHP 错误/警告不会泄露到页面，避免敏感信息暴露
WAF_ERROR_MASKING=true

# 数据库调试模式（生产环境务必 false）
WAF_DB_DEBUG=false

# WAF 调试模式：开启后输出详细检测日志（生产环境务必 false）
WAF_DEBUG=false

# 存储目录：用于 RaceCondition 等模块的临时文件存储
# 留空默认使用系统临时目录下的 shield-waf
WAF_STORAGE_DIR=

# 上传路径白名单：识别为上传目录的路径前缀
WAF_UPLOAD_PATH=/wp-content/uploads/

# WordPress 密码策略集成（设为 true 自动接管 wp_hash_password/wp_check_password）
WAF_PASSWORD_WP_INTEGRATION=false

# ======================== 核心性能配置 ========================

# 请求体最大读取大小（字节），1MB
WAF_MAX_BODY_SIZE=1048576

# 最大编码递归深度
WAF_MAX_ENCODING_DEPTH=8

# 单个参数最大长度
WAF_MAX_PAYLOAD_SIZE=100000

# 单日志文件最大大小（字节），10MB
WAF_LOG_MAX_SIZE=10485760
# 旧版变量名（已弃用，保留向后兼容）
# WAF_LOG_MAX_FILESIZE=10485760

# APCu 缓存开关（自动检测环境）
WAF_APCU_ENABLED=

# 输入参数最大长度（字节）
WAF_INPUT_MAX_LENGTH=8192

# CC 攻击 APCu 缓存 TTL（秒）
WAF_CC_APCU_TTL=60

# 恶意扫描缓存 TTL（秒）
WAF_MALWARE_SCAN_CACHE_TTL=300

# 大文件分块扫描大小（字节），1MB
WAF_LARGE_FILE_CHUNK_SIZE=1048576

# 正则预过滤（启用可提升性能）
WAF_REGEX_PREFILTER=true

# 组合模式（多规则合并匹配，提升性能）
WAF_COMBINED_PATTERN=true

# ======================== 安全功能开关 ========================

# 语义引擎开关
WAF_SEMANTIC_ENABLED=true

# 评分系统开关
WAF_SCORER_ENABLED=true

# 自动学习开关
WAF_AUTOLEARN_ENABLED=true

# 登录后重新生成 session id
WAF_SESSION_REGENERATE=true

# 自定义 CSP 字符串（留空用默认）
SHIELD_WAF_CSP=

# 自定义权限策略（留空用默认）
SHIELD_WAF_PERMISSIONS_POLICY=

# ======================== CORS 配置 ========================

# 允许的 CORS 源，逗号分隔，留空=同源
WAF_CORS_ALLOWED_ORIGINS=
# 旧版变量名（已弃用，保留向后兼容）
# WAF_ALLOWED_ORIGINS=

# ======================== 沙箱配置 ========================

# 沙箱工作模式（重要！）：
#   learning   - 学习模式（首次安装默认）：只扫描告警，不删除任何文件
#   protecting  - 保护模式：基线锁定后，秒删除新文件+精准切割被篡改文件
#
# 工作流程：
#   1. 首次安装 → 保持 learning 模式
#   2. 手动扫描排查后门 → 清理干净
#   3. 调用 lockBaseline() 建立基线（API/CLI）
#   4. 切换到 protecting 模式 → 启动秒删除+精准切割
WAF_SANDBOX_MODE=learning

# 自动扫描间隔（秒），默认 300 = 5 分钟
WAF_SANDBOX_SCAN_INTERVAL=300

# 恶意代码判定阈值（评分 >= 此值即判定为恶意）
# 多引擎交叉验证会动态降低阈值（命中引擎越多阈值越低）
WAF_SANDBOX_MALWARE_THRESHOLD=50

# 新落地的恶意文件是否秒删除
# true = 直接删除，false = 移入隔离区
# 注意：仅 protecting 模式下生效，learning 模式只告警不删除
WAF_SANDBOX_INSTANT_DELETE_NEW=true

# 修改的现有文件含恶意代码时是否自动隔离
# true = 自动隔离待审核，false = 仅告警
# 注意：protecting 模式下，基线中的文件被修改时优先使用精准切割
WAF_SANDBOX_AUTO_QUARANTINE=true

# 沙箱↔AutoLearn 联动开关（推荐开启）
# 启用后激活 3 个集成点：
#   1. 沙箱事件回流：秒删/精准切割/隔离时把来源 IP 标记高危
#      该 IP 下次请求即被 AutoLearn 加成拦截，无需等下次沙箱扫描
#   2. 特征反哺：AutoLearn 高频攻击特征（hit_count>=10）合并到沙箱扫描
#      只读建议，最多加 10 分，不能单独触发判定（防反向污染）
#   3. 基线联动：lockBaseline 时同时冻结 AutoLearn 行为基线
#      防止攻击者在保护模式下"教坏" AutoLearn
WAF_SANDBOX_LEARN_COUPLING=true

# ======================== 上传检测配置 ========================

# 是否启用文件上传检测
WAF_UPLOAD_DETECTION=true

# 是否使用 GD 库验证图像真实性（比 finfo 更严格，能识别图像马）
WAF_UPLOAD_GD_VERIFY=true

# 是否允许 SVG 上传（SVG 可携带脚本和 XXE，风险较高）
WAF_UPLOAD_ALLOW_SVG=false

# 上传文件内容恶意评分阈值（>= 此值直接拦截）
# 多引擎交叉验证会动态降低阈值
WAF_UPLOAD_BLOCK_THRESHOLD=60

# 上传文件内容可疑阈值（>= 此值记录日志，< 此值放行）
WAF_UPLOAD_LOG_THRESHOLD=30

# 上传文件扫描最大大小（字节），超过此大小只扫描头部和尾部
# 默认 5MB
WAF_UPLOAD_SCAN_MAX_SIZE=5242880

# 上传检测拦截时是否触发累进封禁
WAF_UPLOAD_BAN_ON_BLOCK=true

# ======================== 语义引擎配置 ========================

# 语义分析是否启用
WAF_SEMANTIC_ENGINE=true

# 语义记忆池是否启用
WAF_SEMANTIC_MEMORY=true

# 攻击链分析是否启用
WAF_ATTACK_CHAIN=true

# ======================== 主动防御配置 ========================

# 主动防御是否启用
WAF_ACTIVE_DEFENSE=true

# 蜜罐是否启用
WAF_HONEYTRAP=true

# 攻击路径预判是否启用
WAF_PATH_PREDICTION=true

# 误报控制是否启用
WAF_FALSE_POSITIVE_GUARD=true

# ======================== 评分系统配置 ========================

# 拦截阈值（总分>=此值拦截）
WAF_SCORE_BLOCK=70

# 监控阈值（总分>=此值记录日志但不拦截）
WAF_SCORE_MONITOR=40
