# 盾甲 WAF - Apache/Nginx 安全规则
# 防止敏感文件被外部访问

# 禁止直接访问 src/ 目录
RedirectMatch 403 ^/src/

# 禁止访问 logs/ 目录
RedirectMatch 403 ^/logs/

# 禁止访问 docker/ 目录
RedirectMatch 403 ^/docker/

# 禁止访问 .env 文件
<Files ".env">
    Require all denied
</Files>

# 禁止访问 .json 配置文件
<FilesMatch "\.json$">
    Require all denied
</FilesMatch>
